# ============================================================
# .htaccess IMMEIT — www.immeit.com
# Hébergement Amen / Apache
# Généré le 2026-06-12
# ============================================================

# ============================================================
# 1. SÉCURITÉ — En-têtes HTTP
# ============================================================
<IfModule mod_headers.c>

  # Empêche le clickjacking : la page ne peut être intégrée en iframe
  # que depuis le même domaine
  Header always set X-Frame-Options "SAMEORIGIN"

  # Empêche le MIME-sniffing des types de contenu
  Header always set X-Content-Type-Options "nosniff"

  # Politique de referrer sécurisée
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions API — désactiver ce qui n'est pas utilisé
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

  # X-XSS-Protection (legacy, mais encore utile sur anciens navigateurs)
  Header always set X-XSS-Protection "1; mode=block"

  # Content Security Policy — adapter selon vos sources réelles
  # ATTENTION : tester en mode report-only d'abord si vous avez
  # des scripts/styles externes (Google Analytics, Fonts, etc.)
  # Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.google-analytics.com;"

  # HSTS — Force HTTPS. N'activer qu'APRÈS avoir vérifié que tout fonctionne en HTTPS.
  # Commencer avec max-age=86400 (1 jour) avant de passer à 31536000 (1 an)
  Header always set Strict-Transport-Security "max-age=86400; includeSubDomains"

  # Supprimer l'en-tête Server qui expose la version Apache
  Header always unset Server
  Header always unset X-Powered-By

</IfModule>

# ============================================================
# 2. REDIRECTION HTTP → HTTPS (si pas déjà configuré en cPanel)
# ============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Forcer HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Forcer www (décommenter si souhaité — cohérence avec canonical)
  # RewriteCond %{HTTP_HOST} !^www\. [NC]
  # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

</IfModule>

# ============================================================
# 3. COMPRESSION GZIP — Réduction de la taille des transferts
# ============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE application/json
  AddOutputFilterByType DEFLATE application/ld+json
  AddOutputFilterByType DEFLATE image/svg+xml
  AddOutputFilterByType DEFLATE font/woff
  AddOutputFilterByType DEFLATE font/woff2
  AddOutputFilterByType DEFLATE application/font-woff
  AddOutputFilterByType DEFLATE application/font-woff2

  # Ne pas compresser les images (déjà compressées)
  SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|ico|zip|gz|mp4)$ no-gzip dont-vary

  # Vary header pour les proxies
  <IfModule mod_headers.c>
    Header append Vary User-Agent env=!dont-vary
  </IfModule>
</IfModule>

# ============================================================
# 4. CACHE — Expiration des assets statiques
# ============================================================
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — cache court (contenu peut changer)
  ExpiresByType text/html                     "access plus 1 hour"

  # CSS et JavaScript — cache 1 an (versionnez vos fichiers si besoin)
  ExpiresByType text/css                      "access plus 1 year"
  ExpiresByType application/javascript        "access plus 1 year"
  ExpiresByType text/javascript               "access plus 1 year"

  # Images — cache 1 an
  ExpiresByType image/jpeg                    "access plus 1 year"
  ExpiresByType image/jpg                     "access plus 1 year"
  ExpiresByType image/png                     "access plus 1 year"
  ExpiresByType image/webp                    "access plus 1 year"
  ExpiresByType image/gif                     "access plus 1 year"
  ExpiresByType image/svg+xml                 "access plus 1 year"
  ExpiresByType image/x-icon                  "access plus 1 year"
  ExpiresByType image/vnd.microsoft.icon      "access plus 1 year"

  # Fonts
  ExpiresByType font/woff                     "access plus 1 year"
  ExpiresByType font/woff2                    "access plus 1 year"
  ExpiresByType application/font-woff         "access plus 1 year"
  ExpiresByType application/font-woff2        "access plus 1 year"

  # XML / JSON
  ExpiresByType application/json              "access plus 0 seconds"
  ExpiresByType application/ld+json           "access plus 1 hour"
  ExpiresByType text/xml                      "access plus 1 hour"
  ExpiresByType application/xml               "access plus 1 hour"

  # robots.txt et sitemap — cache court
  ExpiresByType text/plain                    "access plus 1 day"

</IfModule>

# Cache-Control en complément
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|webp|jpg|jpeg|png|gif|svg|woff|woff2|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# ============================================================
# 5. TYPES MIME — Ajout WebP et fonts modernes
# ============================================================
<IfModule mod_mime.c>
  AddType image/webp                          .webp
  AddType font/woff                           .woff
  AddType font/woff2                          .woff2
  AddType application/ld+json                 .jsonld
</IfModule>

# ============================================================
# 6. PAGES D'ERREUR PERSONNALISÉES (optionnel)
# ============================================================
# ErrorDocument 404 /404.html
# ErrorDocument 403 /403.html

# ============================================================
# 7. PROTECTION — Interdire l'accès aux fichiers sensibles
# ============================================================
<FilesMatch "(\.htaccess|\.htpasswd|\.env|\.git|config\.php|php-error\.log)$">
  Order Allow,Deny
  Deny from all
</FilesMatch>

# Empêcher le listing des répertoires
Options -Indexes

# ============================================================
# FIN DU FICHIER .htaccess
# ============================================================
